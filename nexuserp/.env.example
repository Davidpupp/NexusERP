# ─────────────────────────────────────────────────────────────
# NexusERP — environment variables
# Copy to .env (dev) and set the real values in Vercel (prod).
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/nexuserp?sslmode=require"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-min-32-chars"

# Public base URL of the deployment (used for auth callbacks + MP webhooks)
AUTH_URL="https://your-domain.com"
NEXTAUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Mercado Pago — leave empty to use the mock checkout in development.
# Get tokens at https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=""
# Secret configured in the MP webhook to validate x-signature
MP_WEBHOOK_SECRET=""
# Public key do Mercado Pago (client) p/ tokenizar cartão com MP.js
NEXT_PUBLIC_MP_PUBLIC_KEY=""

# Email — Resend (https://resend.com). Vazio = e-mails só no console (dev).
RESEND_API_KEY=""
EMAIL_FROM="NexusERP <no-reply@seu-dominio.com>"

# Upstash Redis (rate-limit distribuído). Vazio = fallback in-memory.
# https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry (observabilidade). Vazio = desativado.
SENTRY_DSN=""

# Claude / Anthropic — recursos de IA (insights, assistente). Vazio = desativado.
# https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Pluggy (Open Finance Brasil) — integração bancária. Vazio = desativado.
# https://dashboard.pluggy.ai
PLUGGY_CLIENT_ID=""
PLUGGY_CLIENT_SECRET=""

# Cron (Vercel Cron) — protege o endpoint /api/cron. Gerar: openssl rand -base64 32
# Vazio = endpoint de cron nega todo acesso (401).
CRON_SECRET=""
